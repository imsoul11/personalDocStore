// Machinery's config imports cloud.google.com/go/pubsub, which can pull legacy
// google.golang.org/genproto that still embeds googleapis/rpc and conflicts with
// the split module google.golang.org/genproto/googleapis/rpc.
exclude google.golang.org/genproto v0.0.0-20210207032614-bba0dbe2a9ea

exclude google.golang.org/genproto v0.0.0-20200526211855-cb27e3aa2013

exclude google.golang.org/genproto v0.0.0-20210108203827-ffc7fda8c3d7

// Force a single genproto line that matches grpc/googleapis/rpc (avoids duplicate
// googleapis/rpc/* packages from legacy monolithic genproto pulled by pubsub).
replace google.golang.org/genproto => google.golang.org/genproto v0.0.0-20260319201613-d00831a3d3e7
